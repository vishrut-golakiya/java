package com.first.helloworld.Controller;
import java.util.*;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.ResponseBody;


import com.first.helloworld.Entitys.AuthorRepository;
import com.first.helloworld.Entitys.Register;


@Controller
@RequestMapping(path="/register")
public class RegisterController {
    @Autowired 
    private AuthorRepository authorRepository;

    @PostMapping(path="/addauthor") 
    public @ResponseBody String addAuthors (@RequestParam String register_name
            , @RequestParam String password) {
      
        
        Register geekAuthor = new Register();
        
        geekAuthor.setUsername(register_name);
        geekAuthor.setPassword(password);
        authorRepository.save(geekAuthor);
        return "Details got Saved";
    }

     @GetMapping(path="/authors")
    public @ResponseBody List<Register> getAllAuthors() {
        return authorRepository.findAll();
    }

     @GetMapping(path="/authors/{userId}")
     public @ResponseBody Register getUserDetails(@PathVariable int userId) {
		return authorRepository.findById(Long.valueOf(userId)).orElse(null);
    	 
     }
}
